<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/img_2"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:gravity="center"
        android:orientation="vertical"
        android:padding="24dp">

        <ImageView
            android:layout_width="150dp"
            android:layout_height="120dp"
            android:contentDescription="Bhavans College Logo"
            android:scaleType="fitCenter"
            app:srcCompat="@drawable/img" />

        <ImageView
            android:layout_width="match_parent"
            android:layout_height="95dp"
            android:layout_marginTop="16dp"
            android:contentDescription="Bhavans College Banner"
            android:scaleType="fitCenter"
            app:srcCompat="@drawable/img_1" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="30dp"
            android:gravity="center"
            android:text="BHAVANS STUDENT PORTAL"
            android:textColor="#FFFFFF"
            android:textSize="26sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:gravity="center"
            android:text="Syllabus • Notes • Homework • College Info"
            android:textColor="#EDE7F6"
            android:textSize="15sp" />

        <Button
            android:id="@+id/startButton"
            android:layout_width="220dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="40dp"
            android:text="START"
            android:textSize="22sp"
            android:textStyle="bold" />

    </LinearLayout>
</ScrollView>
